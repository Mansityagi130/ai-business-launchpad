{
  "name": "ai-business-launchpad",
  "version": "1.0.0",
  "private": true,
  "description": "AI Business Launchpad Monorepo",
  "scripts": {
    "dev:api": "pnpm --filter @launchpad/api dev",
    "dev:web": "pnpm --filter @launchpad/web dev",
    "dev:mobile": "pnpm --filter @launchpad/mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
